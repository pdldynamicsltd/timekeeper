@using CadentManagement.Authorization
@using CadentManagement.Web.Areas.App.Startup
@{
    ViewBag.CurrentPageName = AppPageNames.Tenant.TimeTrackingMyWeek;
}

@section Styles
{
    <link rel="stylesheet" abp-href="/view-resources/Areas/App/Views/Shared/AppWorkspace.css" asp-append-version="true" />
    <link rel="stylesheet" abp-href="/Common/Styles/dhtmlxscheduler.min.css" asp-append-version="true" />
    <link rel="stylesheet" abp-href="/view-resources/Areas/App/Views/TimeTracking/MyWeek.css" asp-append-version="true" />
}

@section Scripts
{
    <script src="/Common/Scripts/dhtmlxscheduler.js" asp-append-version="true"></script>
    <script src="/view-resources/Areas/App/Views/TimeTracking/MyWeek.js" asp-append-version="true"></script>
}

<abp-page-subheader title="@L("MyWeek")" description="@L("MyWeekDescription")">
    <button id="LogTimeButton" class="btn btn-primary">
        <i class="fa fa-plus btn-md-icon"></i>
        <span class="d-none d-md-inline-block">@L("LogTime")</span>
    </button>
</abp-page-subheader>

<div class="@(await GetContainerClass()) time-workspace">

    
    <div class="card app-workspace-card mb-4">
        <div class="card-body py-3">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div class="d-flex align-items-center gap-2">
                    <button id="PrevWeekButton" class="btn btn-sm btn-light-primary">
                        <i class="ki-outline ki-arrow-left fs-4"></i>
                        @L("PreviousPeriod")
                    </button>
                    <button id="TodayButton" class="btn btn-sm btn-light">
                        @L("CurrentPeriod")
                    </button>
                    <button id="NextWeekButton" class="btn btn-sm btn-light-primary">
                        @L("NextPeriod")
                        <i class="ki-outline ki-arrow-right fs-4"></i>
                    </button>
                    <span id="WeekLabel" class="fw-bold fs-5 ms-2"></span>
                </div>
                <div class="d-flex align-items-center gap-4">
                    <div class="tw-stat-tile text-center align-items-center">
                        <span class="tw-stat-value" id="WeekTotalHours">0.0</span>
                        <span class="tw-stat-label">@L("TotalThisPeriod")</span>
                    </div>
                </div>
            </div>
            <div class="week-summary-bar mt-3" id="WeekProjectSummary"></div>
        </div>
    </div>

    
    <div class="card app-workspace-card app-workspace-page">
        <div class="card-body p-0">
            <div id="myWeekScheduler"></div>
        </div>
    </div>

</div>


<div id="timeEntryModalContainer"></div>
